# Vercel Storage / Upstash Redis URL (automatically injected by Vercel Integration)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# MongoDB Connection String (Atlas or self-hosted)
MONGODB_URI=

# Firebase Admin configuration for the Vercel serverless API.
# Recommended: paste the complete service-account JSON as one Vercel env value.
# Do not add extra wrapping quotes in the Vercel dashboard.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT=

# Recommended when the site will contain many coach/member/article images.
# Example: vvnxomchieu.firebasestorage.app (copy the exact bucket name from
# Firebase Console > Storage). Firebase Storage currently requires Blaze.
FIREBASE_STORAGE_BUCKET=

# Optional but recommended: a long random value used to sign HttpOnly Admin
# sessions. If omitted, the server derives a stable secret from Firebase config.
ADMIN_SESSION_SECRET=

# Emergency bootstrap only when the private Firebase admin_accounts document
# does not exist yet. Leave these empty on an already initialized production
# site. Remove ADMIN_BOOTSTRAP_PASSWORD after the first successful login.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=
